{
  "name": "@south-loop-studios/cf-pages-cleaner",
  "version": "0.1.0",
  "description": "Clean up old Cloudflare Pages deployments — terminal UI with an optional local web GUI.",
  "type": "module",
  "main": "src/index.mjs",
  "bin": {
    "cf-pages-cleaner": "bin/cf-pages-cleaner.mjs"
  },
  "files": [
    "bin",
    "src",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.17"
  },
  "scripts": {
    "start": "node bin/cf-pages-cleaner.mjs",
    "dev": "node bin/cf-pages-cleaner.mjs",
    "prepublishOnly": "node bin/cf-pages-cleaner.mjs --version >/dev/null"
