  "repository": {
    "type": "git",
    "url": "git+https://github.com/South-Loop-Studios/cf-pages-cleaner.git"
  },
  "homepage": "https://github.com/South-Loop-Studios/cf-pages-cleaner#readme",
  "bugs": {
    "url": "https://github.com/South-Loop-Studios/cf-pages-cleaner/issues"
  },
  "dependencies": {
